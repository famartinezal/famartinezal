---
import { personal, experience } from '../data/portfolio';
---

<section id="sobre-mi" class="py-28 lg:py-36">
  <div class="max-w-6xl mx-auto px-6">

    <p class="label mb-3" data-reveal>01 — Sobre mí</p>
    <h2
      class="text-3xl sm:text-4xl font-bold tracking-tight mb-16 leading-tight"
      style="color: var(--hi);"
      data-reveal data-reveal-d1
    >
      Datos que cuentan historias.<br/>
      <span class="text-grad-blue">Código que escala.</span>
    </h2>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">

      <!-- Bio + focus cards -->
      <div data-reveal data-reveal-d2>
        <p class="leading-relaxed text-base mb-8" style="color: var(--mid);">{personal.bio}</p>

        <div class="space-y-3">
          {[
            { icon: '◈', title: 'Teledetección SAR',
              desc: 'Procesamiento de imágenes Sentinel-1 para monitoreo agrícola a escala nacional.' },
            { icon: '◈', title: 'Machine Learning',
              desc: 'Clasificación de cultivos, detección de fenología y análisis de series de tiempo.' },
            { icon: '◈', title: 'Desarrollo de software',
              desc: 'APIs, dashboards y pipelines de datos geoespaciales listos para producción.' },
          ].map((item) => (
            <div class="card card-glow flex gap-4 p-4 group cursor-default">
              <span class="font-mono mt-0.5 shrink-0 transition-colors duration-200 group-hover:text-accent-l"
                    style="color: var(--accent);">{item.icon}</span>
              <div>
                <p class="text-sm font-semibold mb-0.5 transition-colors duration-200 group-hover:text-white"
                   style="color: var(--hi);">{item.title}</p>
                <p class="text-sm" style="color: var(--mid);">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Experience timeline -->
      <div data-reveal data-reveal-d3>
        <p class="label mb-8">Experiencia</p>
        <ol class="space-y-0">
          {experience.map((job, i) => (
            <li class="flex gap-5 pb-10 last:pb-0 group">
              <div class="flex flex-col items-center pt-1.5 shrink-0">
                <div
                  class="w-2.5 h-2.5 rounded-full shrink-0 dot-pulse transition-transform duration-200 group-hover:scale-125"
                  style="background: var(--accent);"
                ></div>
                {i < experience.length - 1 && (
                  <div class="flex-1 w-px mt-2 min-h-[32px]" style="background: var(--border);"></div>
                )}
              </div>
              <div>
                <p class="label mb-1">{job.period}</p>
                <p class="text-base font-semibold mb-0.5 transition-colors duration-200 group-hover:text-white"
                   style="color: var(--hi);">{job.org}</p>
                <p class="text-sm font-medium mb-2" style="color: var(--accent-l);">{job.role}</p>
                <p class="text-sm leading-relaxed" style="color: var(--mid);">{job.desc}</p>
              </div>
            </li>
          ))}
        </ol>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mt-2"
             style="background: var(--card); border: 1px solid var(--border);">
          <span class="w-1.5 h-1.5 rounded-full shrink-0"
                style="background: var(--green); animation: glowPulse 2s ease-in-out infinite;"></span>
          <span class="text-xs font-mono" style="color: var(--mid);">{personal.location}</span>
        </div>
      </div>
    </div>
  </div>
</section>
