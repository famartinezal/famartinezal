---
import { personal, experience } from '../data/portfolio';
---

<section id="about" class="py-28 lg:py-36">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">

    <!-- Section header -->
    <div class="mb-16" data-reveal>
      <p class="text-xs font-mono text-accent-light uppercase tracking-[0.2em] mb-3">01 — About</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">A bit about me</h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left: Bio -->
      <div class="space-y-6" data-reveal data-reveal-delay="1">
        <div class="space-y-4 text-subtle leading-relaxed text-base">
          {personal.bio.split('\n').filter(Boolean).map((paragraph) => (
            <p>{paragraph.trim()}</p>
          ))}
        </div>

        <!-- What I do -->
        <div class="mt-8 p-6 rounded-2xl bg-surface-2 border border-border space-y-4">
          <p class="text-xs font-mono text-accent-light uppercase tracking-widest">What I focus on</p>
          <ul class="space-y-3">
            {[
              { icon: '⬡', text: 'Building scalable front-end architectures with React & TypeScript' },
              { icon: '⬡', text: 'Designing clean, performant REST and GraphQL APIs' },
              { icon: '⬡', text: 'Turning complex problems into simple, intuitive UI' },
              { icon: '⬡', text: 'Developer tooling, CI/CD, and infrastructure-as-code' },
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm text-subtle">
                <span class="text-accent-light mt-0.5 shrink-0">{item.icon}</span>
                <span>{item.text}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="flex items-center gap-4 pt-2">
          <span class="text-sm text-muted font-mono">{personal.location}</span>
          <span class="w-1 h-1 rounded-full bg-surface-4"></span>
          <span class="flex items-center gap-1.5 text-sm text-green-400 font-mono">
            <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
            Available for work
          </span>
        </div>
      </div>

      <!-- Right: Experience timeline -->
      <div data-reveal data-reveal-delay="2">
        <p class="text-xs font-mono text-accent-light uppercase tracking-[0.2em] mb-8">Experience</p>
        <ol class="relative space-y-0">
          {experience.map((job, index) => (
            <li class="relative flex gap-6 pb-10 last:pb-0 group">
              <!-- Timeline line -->
              <div class="relative flex flex-col items-center" aria-hidden="true">
                <div class="w-2.5 h-2.5 rounded-full bg-accent border-2 border-surface mt-1 shrink-0 group-hover:scale-125 transition-transform duration-200"></div>
                {index < experience.length - 1 && (
                  <div class="flex-1 w-px bg-border mt-2 min-h-full"></div>
                )}
              </div>
              <!-- Content -->
              <div class="pb-1">
                <div class="flex flex-wrap items-baseline gap-2 mb-1">
                  <span class="text-base font-semibold text-white">{job.company}</span>
                  <span class="text-xs font-mono text-muted">{job.period}</span>
                </div>
                <p class="text-sm text-accent-light font-medium mb-2">{job.role}</p>
                <p class="text-sm text-subtle leading-relaxed">{job.description}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </div>
</section>
