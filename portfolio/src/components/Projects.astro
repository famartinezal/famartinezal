---
import { projects } from '../data/portfolio';

const headers = [
  { a: '#1e3a5f', b: '#0a1628' },
  { a: '#064e3b', b: '#021a14' },
  { a: '#3730a3', b: '#1e1b4b' },
  { a: '#78350f', b: '#1c0a00' },
  { a: '#134e4a', b: '#031c1b' },
  { a: '#581c87', b: '#1a0533' },
];
---

<section id="proyectos" class="py-28 lg:py-36">
  <div class="max-w-6xl mx-auto px-6">

    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-14">
      <div data-reveal>
        <p class="label mb-3">02 — Proyectos</p>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight" style="color: var(--hi);">
          Trabajo seleccionado
        </h2>
      </div>
      <a
        href="https://github.com/famartinezal"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-1.5 text-sm font-medium transition-colors duration-200 shrink-0"
        style="color: var(--lo);"
        onmouseover="this.style.color='var(--hi)'"
        onmouseout="this.style.color='var(--lo)'"
        data-reveal data-reveal-d2
      >
        Ver todo en GitHub
        <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
        </svg>
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {projects.map((p, i) => (
        <article
          class="card card-glow flex flex-col overflow-hidden group"
          data-reveal
          style={`transition-delay: ${i * 60}ms;`}
        >
          <!-- Visual header -->
          <div
            class="h-36 relative overflow-hidden"
            style={`background: linear-gradient(140deg, ${headers[i % headers.length].a} 0%, ${headers[i % headers.length].b} 100%);`}
          >
            <!-- Grid lines -->
            <div
              class="absolute inset-0 transition-opacity duration-300 group-hover:opacity-100"
              style="background-image: linear-gradient(rgba(255,255,255,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.06) 1px, transparent 1px); background-size: 22px 22px; opacity: 0.5;"
              aria-hidden="true"
            ></div>
            <!-- Glow hover overlay -->
            <div
              class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-400"
              style="background: radial-gradient(ellipse at 50% 100%, rgba(59,130,246,0.15) 0%, transparent 70%);"
              aria-hidden="true"
            ></div>
            <!-- Index number -->
            <span
              class="absolute top-2 right-4 font-mono text-6xl font-black leading-none select-none transition-transform duration-300 group-hover:scale-110"
              style="color: rgba(255,255,255,0.07); transform-origin: right top;"
            >
              {String(i + 1).padStart(2, '0')}
            </span>
            <!-- Meta -->
            <div class="absolute bottom-3 left-4 flex items-center gap-2">
              <span class="label" style="font-size:0.6rem; color:rgba(255,255,255,0.4);">{p.year}</span>
              {p.featured && (
                <span
                  class="px-1.5 py-0.5 rounded-md label"
                  style="font-size:0.6rem; background:rgba(59,130,246,0.22); color:#93c5fd; border: 1px solid rgba(59,130,246,0.3);"
                >
                  destacado
                </span>
              )}
            </div>
          </div>

          <!-- Body -->
          <div class="flex flex-col flex-1 p-5">
            <h3
              class="text-sm font-semibold mb-2 transition-colors duration-200 group-hover:text-accent-l"
              style="color: var(--hi);"
            >
              {p.title}
            </h3>
            <p class="text-sm leading-relaxed mb-4 flex-1" style="color: var(--mid);">
              {p.description}
            </p>
            <div class="flex flex-wrap gap-1.5 mb-4">
              {p.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            <div class="flex items-center gap-4 pt-4" style="border-top: 1px solid var(--border);">
              <a
                href={p.github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-xs font-medium transition-colors duration-200"
                style="color: var(--lo);"
                onmouseover="this.style.color='var(--hi)'"
                onmouseout="this.style.color='var(--lo)'"
              >
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
                Código
              </a>
              {p.demo !== '#' && (
                <>
                  <span class="w-px h-3 shrink-0" style="background: var(--border);"></span>
                  <a
                    href={p.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 text-xs font-medium transition-colors duration-200"
                    style="color: var(--accent-l);"
                    onmouseover="this.style.color='var(--hi)'"
                    onmouseout="this.style.color='var(--accent-l)'"
                  >
                    Demo
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
                    </svg>
                  </a>
                </>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
