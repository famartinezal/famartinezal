---
import { projects } from '../data/portfolio';
---

<section id="projects" class="py-28 lg:py-36">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">

    <!-- Section header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-16" data-reveal>
      <div>
        <p class="text-xs font-mono text-accent-light uppercase tracking-[0.2em] mb-3">02 — Work</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">Selected projects</h2>
      </div>
      <a
        href="https://github.com/yourusername"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2 text-sm text-subtle hover:text-white font-medium transition-colors duration-200 shrink-0"
      >
        View all on GitHub
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <!-- Featured projects (larger cards) -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((project, index) => (
        <article
          class="group relative flex flex-col rounded-2xl bg-surface-1 border border-border hover:border-border-hover overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/40"
          data-reveal
          data-reveal-delay={String(Math.min(index + 1, 6))}
        >
          <!-- Project image / placeholder -->
          <div class="relative h-44 overflow-hidden bg-surface-2">
            <!-- Gradient placeholder (replace with real img when available) -->
            <div
              class="absolute inset-0 opacity-60"
              style={{
                background: [
                  'linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #4c1d95 100%)',
                  'linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%)',
                  'linear-gradient(135deg, #0d0d1a 0%, #1a1a2e 50%, #16213e 100%)',
                  'linear-gradient(135deg, #1a0533 0%, #2d1b69 50%, #11032e 100%)',
                  'linear-gradient(135deg, #0d1117 0%, #161b22 50%, #21262d 100%)',
                  'linear-gradient(135deg, #0a0e27 0%, #1a2050 50%, #0d1117 100%)',
                ][index % 6],
              }}
            ></div>
            <!-- Grid overlay decoration -->
            <div
              class="absolute inset-0 opacity-10"
              style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 24px 24px;"
            ></div>
            <!-- Project number -->
            <div class="absolute top-4 left-4 font-mono text-6xl font-bold text-white/5 select-none leading-none">
              {String(index + 1).padStart(2, '0')}
            </div>
            <!-- Featured badge -->
            {project.featured && (
              <span class="absolute top-3 right-3 px-2 py-0.5 rounded-md bg-accent/20 border border-accent/30 text-accent-light text-xs font-mono">
                featured
              </span>
            )}
          </div>

          <!-- Content -->
          <div class="flex flex-col flex-1 p-5">
            <h3 class="text-base font-semibold text-white mb-2 group-hover:text-accent-light transition-colors duration-200">
              {project.title}
            </h3>
            <p class="text-sm text-subtle leading-relaxed mb-4 flex-1">
              {project.description}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mb-5">
              {project.tags.slice(0, 4).map((tag) => (
                <span class="px-2 py-0.5 rounded-md bg-surface-3 text-xs font-mono text-muted border border-border">
                  {tag}
                </span>
              ))}
              {project.tags.length > 4 && (
                <span class="px-2 py-0.5 rounded-md bg-surface-3 text-xs font-mono text-muted border border-border">
                  +{project.tags.length - 4}
                </span>
              )}
            </div>

            <!-- Links -->
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <a
                href={project.demo}
                target="_blank"
                rel="noopener noreferrer"
                class="group/link inline-flex items-center gap-1.5 text-xs font-medium text-accent-light hover:text-white transition-colors duration-200"
              >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
                Live demo
                <svg class="w-3 h-3 group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </a>
              <span class="w-px h-3 bg-border"></span>
              <a
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                class="group/link inline-flex items-center gap-1.5 text-xs font-medium text-subtle hover:text-white transition-colors duration-200"
              >
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
                Source
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
