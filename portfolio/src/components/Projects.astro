---
import { projects } from '../data/portfolio';
// Gradientes de header — paleta esmeralda/slate, sin azules
const headers = [
  { a: '#0d2c1e', b: '#051309' },
  { a: '#092e22', b: '#03150e' },
  { a: '#0a2a1c', b: '#040f09' },
  { a: '#112b1a', b: '#061209' },
  { a: '#0e2c20', b: '#05130a' },
  { a: '#0c281b', b: '#040f08' },
];
---

<!-- Proyectos: vuelve a background — alternancia de capas crea ritmo sin bordes -->
<section id="proyectos" class="surface">
  <div class="max-w-6xl mx-auto px-8 py-36 lg:py-44">

    <!-- Header con "Asymmetric Air" — texto a la izquierda, link a la derecha flotando -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-20">
      <div data-reveal>
        <p class="t-label mb-5">02 — Proyectos</p>
        <h2 class="t-headline" style="font-size: clamp(2rem, 5vw, 3.25rem);">
          Trabajo seleccionado
        </h2>
      </div>
      <a
        href="https://github.com/famartinezal"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-tertiary shrink-0 group"
        data-reveal data-reveal-d1
      >
        Ver todo en GitHub
        <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
        </svg>
      </a>
    </div>

    <!-- Grid: 3 columnas, cards sin bordes — solo surface_mid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {projects.map((p, i) => (
        <article
          class="card card-glow flex flex-col overflow-hidden group"
          data-reveal
          style={`transition-delay: ${i * 55}ms;`}
        >
          <!-- Visual header — gradiente esmeralda oscuro -->
          <div
            class="h-36 relative overflow-hidden"
            style={`background: linear-gradient(145deg, ${headers[i % headers.length].a} 0%, ${headers[i % headers.length].b} 100%);`}
          >
            <!-- Dot grid overlay -->
            <div
              class="absolute inset-0 transition-opacity duration-300 group-hover:opacity-100"
              style="background-image: radial-gradient(circle, rgba(105,246,184,0.1) 1px, transparent 1px); background-size: 16px 16px; opacity: 0.4;"
              aria-hidden="true"
            ></div>
            <!-- Signature glow al hover — un solo focal point (design.md) -->
            <div
              class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-400"
              style="background: radial-gradient(ellipse at 50% 100%, rgba(105,246,184,0.12) 0%, transparent 70%);"
              aria-hidden="true"
            ></div>
            <!-- Index -->
            <span
              class="absolute top-2 right-4 font-mono font-black leading-none select-none transition-transform duration-300 group-hover:scale-110"
              style="font-size: 3.5rem; color: rgba(105,246,184,0.06); transform-origin: right top;"
            >{String(i + 1).padStart(2, '0')}</span>
            <!-- Meta -->
            <div class="absolute bottom-3 left-4 flex items-center gap-2">
              <span class="t-label" style="font-size:0.55rem; color:rgba(105,246,184,0.45);">{p.year}</span>
              {p.featured && (
                <span class="t-label px-2 py-0.5 rounded-full"
                      style="font-size:0.55rem; background:rgba(105,246,184,0.15); color:var(--primary);">
                  destacado
                </span>
              )}
            </div>
          </div>

          <!-- Body — separación solo por spacing (design.md: sin divisores) -->
          <div class="flex flex-col flex-1 p-5">
            <h3
              class="font-bold mb-2 transition-colors duration-200 group-hover:text-emerald-300"
              style="font-size: 0.875rem; color: var(--on-surface);"
            >{p.title}</h3>

            <p class="t-body text-sm leading-relaxed mb-5 flex-1">{p.description}</p>

            <!-- Tags — pill con primary_container (design.md) -->
            <div class="flex flex-wrap gap-1.5 mb-5">
              {p.tags.map((t) => <span class="tag">{t}</span>)}
            </div>

            <!-- Links — tertiary buttons, sin borde -->
            <div class="flex items-center gap-3 mt-auto">
              <a href={p.github} target="_blank" rel="noopener noreferrer" class="btn-tertiary p-0 text-xs gap-1.5">
                <svg class="w-3.5 h-3.5 icon-glow" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
                Código
              </a>
              {p.demo !== '#' && (
                <a href={p.demo} target="_blank" rel="noopener noreferrer"
                   class="btn-tertiary p-0 text-xs gap-1 text-emerald-400 hover:text-white">
                  Demo
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
