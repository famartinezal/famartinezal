---
const links = [
  { label: 'Sobre mí',  href: '#sobre-mi'  },
  { label: 'Proyectos', href: '#proyectos'  },
  { label: 'Skills',    href: '#skills'     },
  { label: 'Contacto',  href: '#contacto'   },
];
---

<header id="nav" class="fixed top-0 inset-x-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="#" class="flex items-center gap-2.5 group">
      <span class="w-8 h-8 rounded-lg bg-accent flex items-center justify-center text-white text-xs font-bold shrink-0">
        FM
      </span>
      <span class="text-sm font-semibold text-mid group-hover:text-hi transition-colors hidden sm:block">
        fredy.dev
      </span>
    </a>

    <!-- Desktop links -->
    <nav class="hidden md:flex items-center gap-1">
      {links.map((l) => (
        <a
          href={l.href}
          class="px-4 py-2 text-sm font-medium text-mid hover:text-hi rounded-lg hover:bg-card transition-all duration-200"
        >
          {l.label}
        </a>
      ))}
    </nav>

    <!-- CTA + toggle -->
    <div class="flex items-center gap-3">
      <a href="#contacto" class="btn-primary hidden sm:inline-flex py-2 px-4 text-sm">
        Hablemos
      </a>
      <button
        id="nav-toggle"
        class="md:hidden p-2 rounded-lg text-mid hover:text-hi hover:bg-card transition-all"
        aria-label="Menú"
      >
        <svg id="ico-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h10"/>
        </svg>
        <svg id="ico-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-nav" class="hidden md:hidden border-t border-border bg-bg">
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-1">
      {links.map((l) => (
        <a
          href={l.href}
          class="mobile-link py-3 px-2 text-sm font-medium text-mid hover:text-hi border-b border-border last:border-0 transition-colors"
        >
          {l.label}
        </a>
      ))}
      <a href="#contacto" class="btn-primary mt-3 justify-center mobile-link">Hablemos</a>
    </div>
  </div>
</header>

<script>
  const nav    = document.getElementById('nav')!;
  const toggle = document.getElementById('nav-toggle')!;
  const menu   = document.getElementById('mobile-nav')!;
  const open   = document.getElementById('ico-open')!;
  const close  = document.getElementById('ico-close')!;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav.style.background = '#0b0b0f';
      nav.style.borderBottom = '1px solid #242429';
    } else {
      nav.style.background = 'transparent';
      nav.style.borderBottom = 'none';
    }
  }, { passive: true });

  toggle.addEventListener('click', () => {
    const hidden = menu.classList.toggle('hidden');
    open.classList.toggle('hidden', !hidden);
    close.classList.toggle('hidden', hidden);
  });

  document.querySelectorAll('.mobile-link').forEach((l) =>
    l.addEventListener('click', () => {
      menu.classList.add('hidden');
      open.classList.remove('hidden');
      close.classList.add('hidden');
    })
  );
</script>
