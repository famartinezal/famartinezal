---
import { skills } from '../data/portfolio';
const cats = [
  { label: 'Ciencia de datos', items: skills.cienciaDatos },
  { label: 'Teledetección',    items: skills.teledeteccion },
  { label: 'Desarrollo',       items: skills.desarrollo    },
];
---

<!-- Skills: surface_low — alterna con sección anterior (background) -->
<section id="skills" class="surface-low">
  <div class="max-w-6xl mx-auto px-8 py-36 lg:py-44">

    <p class="t-label mb-5" data-reveal>03 — Skills</p>
    <h2
      class="t-headline mb-20"
      style="font-size: clamp(2rem, 5vw, 3.25rem);"
      data-reveal data-reveal-d1
    >
      Tecnologías que uso
    </h2>

    <!-- Tres columnas: separación solo por tono (surface_mid) — sin divisores 1px -->
    <div class="grid sm:grid-cols-3 gap-4 mb-4" data-reveal data-reveal-d2>
      {cats.map((cat, i) => (
        <div
          class="surface-mid rounded-2xl p-7 transition-all duration-300 hover:-translate-y-1"
          style={`transition-delay: ${i * 80}ms;`}
        >
          <p class="t-label mb-6">{cat.label}</p>
          <div class="flex flex-wrap gap-2">
            {cat.items.map((skill) => (
              <span class="tag">{skill}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Explorando ahora — surface_container_high, shift más elevado -->
    <div
      class="surface-high rounded-2xl p-6 flex flex-col sm:flex-row sm:items-center gap-5"
      data-reveal data-reveal-d3
    >
      <!-- Signature glow en el ícono (design.md) -->
      <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0"
           style="background: rgba(105,246,184,0.1);">
        <svg class="w-5 h-5 icon-glow" style="color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
        </svg>
      </div>
      <div>
        <p class="font-bold mb-1" style="color: var(--on-surface); font-size: 0.875rem;">Explorando ahora</p>
        <p class="t-body text-sm">
          Deep Learning para imágenes satelitales · Rust · Infraestructura cloud para datos geoespaciales
        </p>
      </div>
    </div>
  </div>
</section>
