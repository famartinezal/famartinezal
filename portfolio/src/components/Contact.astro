---
import { personal } from '../data/portfolio';
const socials = [
  {
    label: 'GitHub', sub: '@famartinezal', href: personal.github,
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
  },
  {
    label: 'LinkedIn', sub: '@famartinezal', href: personal.linkedin,
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
];
---

<!-- Contacto: vuelve a background — alternancia de capas -->
<section id="contacto" class="surface">
  <div class="max-w-6xl mx-auto px-8 py-36 lg:py-44">

    <p class="t-label mb-5" data-reveal>04 — Contacto</p>

    <!-- Headline display grande — "Asymmetric Air" en la columna derecha -->
    <div class="max-w-xl mb-20" data-reveal data-reveal-d1>
      <h2
        class="t-display mb-6"
        style="font-size: clamp(2.5rem, 7vw, 4.5rem);"
      >
        ¿Tienes un<br/>
        <span class="text-emerald">proyecto</span><br/>
        en mente?
      </h2>
      <p class="t-body text-base">
        Disponible para colaboraciones, proyectos freelance o posiciones full-time.
        Si trabajas con datos geoespaciales o necesitas un developer serio, hablemos.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-start">

      <!-- Izquierda: email + socials -->
      <div class="flex flex-col gap-3" data-reveal data-reveal-d2>

        <!-- Email — card surface_mid, sin borde rígido -->
        <div class="surface-mid rounded-2xl p-5 flex items-center justify-between gap-4">
          <div>
            <p class="t-label mb-1.5" style="font-size: 0.6rem;">Email directo</p>
            <p class="font-mono font-bold" style="color: var(--on-surface); font-size: 0.9rem;">{personal.email}</p>
          </div>
          <button
            id="copy-btn"
            data-email={personal.email}
            class="btn-secondary py-2 px-4 text-xs shrink-0"
            aria-label="Copiar email"
          >
            <svg id="ico-copy" class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
            <svg id="ico-ok" class="w-3.5 h-3.5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span id="copy-lbl">Copiar</span>
          </button>
        </div>

        {socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="card surface-mid flex items-center gap-4 p-5 group rounded-2xl"
          >
            <span
              class="transition-all duration-200 group-hover:icon-glow"
              style="color: var(--on-surface-variant);"
              set:html={s.icon}
            ></span>
            <div class="flex-1">
              <p class="font-semibold text-sm" style="color: var(--on-surface);">{s.label}</p>
              <p class="font-mono text-xs" style="color: var(--on-surface-variant);">{s.sub}</p>
            </div>
            <svg
              class="w-4 h-4 transition-all duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
              style="color: var(--on-surface-variant);"
              fill="none" stroke="currentColor" viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </a>
        ))}
      </div>

      <!-- Derecha: form — inputs con surface_low y ghost border en focus (design.md) -->
      <form
        action={`mailto:${personal.email}`}
        method="GET"
        class="flex flex-col gap-4"
        data-reveal data-reveal-d3
      >
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <!-- Labels flotando sobre el input (design.md) -->
            <label class="t-label block mb-2" style="font-size:0.6rem;" for="f-name">Nombre</label>
            <input id="f-name" type="text" name="name" required placeholder="Tu nombre" class="input"/>
          </div>
          <div>
            <label class="t-label block mb-2" style="font-size:0.6rem;" for="f-email">Email</label>
            <input id="f-email" type="email" name="email" required placeholder="tu@email.com" class="input"/>
          </div>
        </div>
        <div>
          <label class="t-label block mb-2" style="font-size:0.6rem;" for="f-msg">Mensaje</label>
          <textarea id="f-msg" name="body" rows={5} required
                    placeholder="Cuéntame sobre tu proyecto..." class="input resize-none"></textarea>
        </div>

        <button type="submit" class="btn-primary w-full justify-center mt-2">
          Enviar mensaje
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </button>

        <p class="text-center font-mono text-xs" style="color: var(--on-surface-variant); opacity: 0.6;">
          Abre tu cliente de correo · Respondo en &lt; 24 h
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  const btn     = document.getElementById('copy-btn');
  const icoCopy = document.getElementById('ico-copy');
  const icoOk   = document.getElementById('ico-ok');
  const lbl     = document.getElementById('copy-lbl');
  btn?.addEventListener('click', () => {
    navigator.clipboard.writeText(btn.dataset.email ?? '').then(() => {
      icoCopy?.classList.add('hidden');
      icoOk?.classList.remove('hidden');
      if (lbl) lbl.textContent = '¡Copiado!';
      setTimeout(() => {
        icoCopy?.classList.remove('hidden');
        icoOk?.classList.add('hidden');
        if (lbl) lbl.textContent = 'Copiar';
      }, 2000);
    });
  });
</script>
