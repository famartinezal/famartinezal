---
import { personal } from '../data/portfolio';

const socials = [
  {
    label: 'GitHub',
    href: personal.github,
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
    description: 'Open source work',
  },
  {
    label: 'LinkedIn',
    href: personal.linkedin,
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
    description: 'Professional network',
  },
  {
    label: 'Twitter / X',
    href: personal.twitter,
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.892-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
    description: 'Thoughts & updates',
  },
];
---

<section id="contact" class="py-28 lg:py-36">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">

    <!-- Section header -->
    <div class="mb-16" data-reveal>
      <p class="text-xs font-mono text-accent-light uppercase tracking-[0.2em] mb-3">04 — Contact</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">Let's build something</h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <!-- Left: CTA block -->
      <div data-reveal data-reveal-delay="1">
        <p class="text-lg text-subtle leading-relaxed mb-8">
          I'm currently open to new opportunities — full-time roles, contract work, and interesting collaborations.
          If you have a project or a position that could use my skills, let's talk.
        </p>

        <!-- Email copy button -->
        <div class="p-5 rounded-2xl bg-surface-1 border border-border flex items-center justify-between gap-4 mb-6 group hover:border-border-hover transition-colors duration-200">
          <div>
            <p class="text-xs font-mono text-muted uppercase tracking-widest mb-1">Email</p>
            <p class="text-white font-medium font-mono">{personal.email}</p>
          </div>
          <button
            id="copy-email"
            data-email={personal.email}
            class="shrink-0 flex items-center gap-2 px-4 py-2 rounded-lg bg-surface-3 hover:bg-accent hover:text-white text-subtle text-sm font-medium transition-all duration-200 border border-border hover:border-accent"
            aria-label="Copy email address"
          >
            <svg id="icon-copy" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
            <svg id="icon-check" class="w-4 h-4 hidden text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span id="copy-label">Copy</span>
          </button>
        </div>

        <!-- Social links -->
        <div class="space-y-3">
          {socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-4 p-4 rounded-xl bg-surface-1 border border-border hover:border-border-hover hover:bg-surface-2 transition-all duration-200"
            >
              <span class="text-subtle group-hover:text-white transition-colors duration-200" set:html={social.icon}></span>
              <div class="flex-1">
                <p class="text-sm font-medium text-white">{social.label}</p>
                <p class="text-xs text-muted">{social.description}</p>
              </div>
              <svg class="w-4 h-4 text-muted group-hover:text-white group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Right: Quick form -->
      <div data-reveal data-reveal-delay="2">
        <form
          id="contact-form"
          class="space-y-4"
          action={`mailto:${personal.email}`}
          method="GET"
          enctype="text/plain"
        >
          <div>
            <label for="name" class="block text-xs font-mono text-muted uppercase tracking-widest mb-2">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Your name"
              class="w-full px-4 py-3 rounded-xl bg-surface-1 border border-border hover:border-border-hover focus:border-accent/60 focus:outline-none focus:ring-1 focus:ring-accent/30 text-white placeholder-muted text-sm transition-all duration-200"
            />
          </div>
          <div>
            <label for="email-input" class="block text-xs font-mono text-muted uppercase tracking-widest mb-2">Email</label>
            <input
              type="email"
              id="email-input"
              name="email"
              required
              placeholder="your@email.com"
              class="w-full px-4 py-3 rounded-xl bg-surface-1 border border-border hover:border-border-hover focus:border-accent/60 focus:outline-none focus:ring-1 focus:ring-accent/30 text-white placeholder-muted text-sm transition-all duration-200"
            />
          </div>
          <div>
            <label for="message" class="block text-xs font-mono text-muted uppercase tracking-widest mb-2">Message</label>
            <textarea
              id="message"
              name="body"
              rows={5}
              required
              placeholder="Tell me about your project..."
              class="w-full px-4 py-3 rounded-xl bg-surface-1 border border-border hover:border-border-hover focus:border-accent/60 focus:outline-none focus:ring-1 focus:ring-accent/30 text-white placeholder-muted text-sm transition-all duration-200 resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="group w-full flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl bg-accent hover:bg-violet-500 text-white font-semibold text-sm transition-all duration-200 glow-accent hover:glow-accent-strong hover:-translate-y-0.5"
          >
            Send message
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </button>
          <p class="text-xs text-muted text-center">Opens your email client. Typical response within 24h.</p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('copy-email');
  const iconCopy = document.getElementById('icon-copy');
  const iconCheck = document.getElementById('icon-check');
  const label = document.getElementById('copy-label');

  btn?.addEventListener('click', () => {
    const email = btn.dataset.email ?? '';
    navigator.clipboard.writeText(email).then(() => {
      iconCopy?.classList.add('hidden');
      iconCheck?.classList.remove('hidden');
      if (label) label.textContent = 'Copied!';
      setTimeout(() => {
        iconCopy?.classList.remove('hidden');
        iconCheck?.classList.add('hidden');
        if (label) label.textContent = 'Copy';
      }, 2000);
    });
  });
</script>
