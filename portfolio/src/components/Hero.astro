---
import { personal } from '../data/portfolio';
---

<section id="hero" class="relative min-h-screen flex flex-col justify-center pt-16 overflow-hidden">

  <!-- Aurora background blobs -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="aurora absolute -top-40 left-1/2 -translate-x-1/2 w-[700px] h-[700px] rounded-full"
         style="background: radial-gradient(circle, rgba(59,130,246,0.10) 0%, transparent 65%);"></div>
    <div class="aurora absolute top-1/3 -left-32 w-[500px] h-[500px] rounded-full"
         style="background: radial-gradient(circle, rgba(139,92,246,0.07) 0%, transparent 65%); animation-delay:-4s;"></div>
    <div class="aurora absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full"
         style="background: radial-gradient(circle, rgba(59,130,246,0.06) 0%, transparent 65%); animation-delay:-8s;"></div>
  </div>

  <!-- Dot grid texture -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0"
       style="background-image: radial-gradient(circle, #27272f 1px, transparent 1px); background-size: 28px 28px; opacity: 0.5;"></div>

  <div class="relative max-w-6xl mx-auto px-6 w-full py-24">

    <!-- Status badge -->
    <div
      class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-card border border-border text-xs font-mono text-mid mb-10"
      style="animation: fadeUp 0.5s cubic-bezier(0.16,1,0.3,1) both;"
    >
      <span class="w-2 h-2 rounded-full bg-green shrink-0"
            style="animation: glowPulse 2s ease-in-out infinite;"></span>
      Disponible para proyectos · Colombia
    </div>

    <!-- Headline con shimmer animado -->
    <h1
      class="text-5xl sm:text-7xl lg:text-[5.5rem] font-black tracking-tight leading-none mb-5 text-grad-animated"
      style="animation: fadeUp 0.65s cubic-bezier(0.16,1,0.3,1) 0.08s both;"
    >
      {personal.name}
    </h1>

    <!-- Role -->
    <p
      class="text-xl sm:text-2xl lg:text-3xl font-light mb-5 tracking-tight"
      style="color: var(--mid); animation: fadeUp 0.65s cubic-bezier(0.16,1,0.3,1) 0.16s both;"
    >
      {personal.role}
      <span class="inline-block w-0.5 h-7 ml-1 cursor-blink align-middle rounded-full"
            style="background: var(--accent);"></span>
    </p>

    <!-- Tagline -->
    <p
      class="text-base sm:text-lg max-w-xl leading-relaxed mb-12"
      style="color: var(--lo); animation: fadeUp 0.65s cubic-bezier(0.16,1,0.3,1) 0.24s both;"
    >
      {personal.tagline}
    </p>

    <!-- CTAs -->
    <div
      class="flex flex-wrap gap-3"
      style="animation: fadeUp 0.65s cubic-bezier(0.16,1,0.3,1) 0.32s both;"
    >
      <a href="#proyectos" class="btn-primary">
        Ver proyectos
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
      <a href="#contacto" class="btn-ghost">Contactar</a>
      <a
        href={personal.github}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:inline-flex items-center gap-2 px-4 py-2 text-sm transition-colors duration-200"
        style="color: var(--lo);"
        onmouseover="this.style.color='var(--hi)'"
        onmouseout="this.style.color='var(--lo)'"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        GitHub
      </a>
    </div>

    <!-- Stats con contador animado -->
    <div
      class="mt-16 pt-10 border-t flex flex-wrap gap-12"
      style="border-color: var(--border); animation: fadeUp 0.65s cubic-bezier(0.16,1,0.3,1) 0.40s both;"
    >
      {[
        { count: 5,   suffix: '+', label: 'Años de experiencia'      },
        { count: 20,  suffix: '+', label: 'Proyectos entregados'      },
        { count: 100, suffix: 'k+', label: 'Ha de cultivos analizadas'},
      ].map((s) => (
        <div>
          <p class="text-3xl font-black" style="color: var(--hi);">
            <span data-count={s.count} data-suffix={s.suffix}>0{s.suffix}</span>
          </p>
          <p class="label mt-1">{s.label}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 float" aria-hidden="true">
    <span class="label" style="font-size:0.6rem;">scroll</span>
    <div class="w-px h-10" style="background: linear-gradient(to bottom, var(--lo), transparent);"></div>
  </div>
</section>
