---
import { personal } from '../data/portfolio';
---

<!-- Hero ocupa la pantalla completa.
     Fondo: background (#0a0f0d).
     La sección de stats usa surface_container_low como shift tonal — sin bordes.
-->
<section id="hero" class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-14 md:pt-0">

  <!-- Aurora blobs — tintados esmeralda según design.md -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="aurora absolute -top-48 left-1/2 -translate-x-1/2 w-[800px] h-[800px] rounded-full"
         style="background: radial-gradient(circle, rgba(105,246,184,0.07) 0%, transparent 60%);"></div>
    <div class="aurora absolute top-1/4 -left-40 w-[600px] h-[600px] rounded-full"
         style="background: radial-gradient(circle, rgba(6,183,127,0.05) 0%, transparent 60%); animation-delay:-5s;"></div>
    <div class="aurora absolute bottom-0 right-0 w-[500px] h-[500px] rounded-full"
         style="background: radial-gradient(circle, rgba(105,246,184,0.04) 0%, transparent 60%); animation-delay:-9s;"></div>
  </div>

  <!-- Dot grid — tintado verde -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0"
       style="background-image: radial-gradient(circle, #1a2420 1px, transparent 1px); background-size: 32px 32px;"></div>

  <!-- "Asymmetric Air" — contenido desplazado a la izquierda,
       columna derecha intencionalmente vacía (más aire) -->
  <div class="relative max-w-6xl mx-auto px-8 w-full py-28 lg:py-40">
    <div class="max-w-2xl">

      <!-- Overline label — primary color, ALL CAPS, tracking 0.1em (design.md) -->
      <p
        class="t-label mb-8"
        style="animation: fadeUp 0.5s cubic-bezier(0.16,1,0.3,1) both;"
      >
        <span class="inline-flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full dot-pulse" style="background: var(--primary);"></span>
          Disponible para proyectos · Colombia
        </span>
      </p>

      <!-- Display: font-weight 800, letter-spacing -0.04em (design.md) -->
      <h1
        class="t-display text-shimmer mb-6"
        style="font-size: clamp(3rem, 9vw, 6rem); animation: fadeUp 0.65s cubic-bezier(0.16,1,0.3,1) 0.08s both;"
      >
        {personal.name}
      </h1>

      <!-- Role -->
      <p
        class="text-xl sm:text-2xl font-light mb-5"
        style="color: var(--on-surface-variant); letter-spacing: -0.01em; animation: fadeUp 0.65s cubic-bezier(0.16,1,0.3,1) 0.16s both;"
      >
        {personal.role}
        <span class="inline-block w-0.5 h-6 ml-1 cursor-blink align-middle rounded-full"
              style="background: var(--primary);"></span>
      </p>

      <!-- Tagline — on_surface_variant, body-lg -->
      <p
        class="text-base sm:text-lg leading-relaxed mb-12 max-w-lg"
        style="color: var(--on-surface-variant); animation: fadeUp 0.65s cubic-bezier(0.16,1,0.3,1) 0.24s both;"
      >
        {personal.tagline}
      </p>

      <!-- CTAs: primary + secondary (design.md) -->
      <div
        class="flex flex-wrap gap-3 mb-20"
        style="animation: fadeUp 0.65s cubic-bezier(0.16,1,0.3,1) 0.32s both;"
      >
        <a href="#proyectos" class="btn-primary">
          Ver proyectos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="#contacto" class="btn-secondary">Contactar</a>
        <a
          href={personal.github}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-tertiary hidden sm:inline-flex"
        >
          <svg class="w-4 h-4 icon-glow" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
      </div>

      <!-- Stats — shift tonal a surface_low, sin borde -->
      <div
        class="surface-low rounded-2xl px-8 py-6 inline-flex flex-wrap gap-10"
        style="animation: fadeUp 0.65s cubic-bezier(0.16,1,0.3,1) 0.40s both;"
      >
        {[
          { count: 5,   suffix: '+',  label: 'Años de experiencia'      },
          { count: 20,  suffix: '+',  label: 'Proyectos entregados'      },
          { count: 100, suffix: 'k+', label: 'Ha de cultivos analizadas' },
        ].map((s) => (
          <div>
            <p class="text-2xl font-extrabold" style="color: var(--primary);">
              <span data-count={s.count} data-suffix={s.suffix}>0{s.suffix}</span>
            </p>
            <p class="t-label mt-1" style="color: var(--on-surface-variant); font-size: 0.6rem;">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-28 md:bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 float" aria-hidden="true">
    <p class="t-label" style="font-size: 0.55rem;">scroll</p>
    <div class="w-px h-10" style="background: linear-gradient(to bottom, var(--primary-c), transparent);"></div>
  </div>
</section>
