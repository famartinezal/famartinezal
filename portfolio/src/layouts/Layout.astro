---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Fredy Martínez — Científico de Datos & Desarrollador',
  description = 'Científico de datos especializado en teledetección SAR, machine learning aplicado al agro y desarrollo de software geoespacial. Colombia.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Fredy Martínez" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/portfolio/favicon.svg" />
  </head>

  <body class="bg-bg text-hi font-sans antialiased overflow-x-hidden">
    <slot />

    <script>
      // ── Scroll reveal ──────────────────────────────────
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
        }),
        { threshold: 0.07, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));

      // ── Stats counter ──────────────────────────────────
      function animateCounter(el: Element) {
        const target = parseInt(el.getAttribute('data-count') ?? '0', 10);
        const duration = 1400;
        const start = performance.now();
        const suffix = el.getAttribute('data-suffix') ?? '';
        const step = (now: number) => {
          const p = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.floor(eased * target) + suffix;
          if (p < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      }

      const counterIO = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) {
            animateCounter(e.target);
            counterIO.unobserve(e.target);
          }
        }),
        { threshold: 0.5 }
      );
      document.querySelectorAll('[data-count]').forEach((el) => counterIO.observe(el));
    </script>

    <style is:global>
      /* ── CSS custom properties ───────────────────── */
      :root {
        --bg:        #0b0b0f;
        --card:      #111116;
        --card-h:    #17171e;
        --border:    #27272f;
        --border-h:  #3f3f4a;
        --hi:        #ffffff;
        --mid:       #c8c8d8;   /* más claro que antes */
        --lo:        #8888a0;   /* más vivo, tinte azul-violeta */
        --accent:    #3b82f6;
        --accent-h:  #2563eb;
        --accent-l:  #93c5fd;
        --green:     #34d399;
      }

      /* ── Base ────────────────────────────────────── */
      .bg-bg   { background-color: var(--bg); }
      .text-hi { color: var(--hi); }
      .text-mid { color: var(--mid); }
      .text-lo  { color: var(--lo); }

      ::selection { background: #3b82f6; color: #fff; }

      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: #3b82f6; border-radius: 99px; }

      /* ── Scroll reveal ───────────────────────────── */
      [data-reveal] {
        opacity: 0;
        transform: translateY(24px);
        transition:
          opacity  0.7s cubic-bezier(0.16, 1, 0.3, 1),
          transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
      }
      [data-reveal].is-visible { opacity: 1; transform: none; }
      [data-reveal-d1] { transition-delay: 0.10s; }
      [data-reveal-d2] { transition-delay: 0.20s; }
      [data-reveal-d3] { transition-delay: 0.30s; }
      [data-reveal-d4] { transition-delay: 0.40s; }

      /* ── Gradient texts ──────────────────────────── */
      .text-grad {
        background: linear-gradient(135deg, #ffffff 0%, #c8c8d8 60%, #8888a0 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Animated shimmer gradient — para el nombre en Hero */
      .text-grad-animated {
        background: linear-gradient(
          110deg,
          #ffffff 20%,
          #93c5fd 38%,
          #ffffff 50%,
          #c084fc 62%,
          #ffffff 80%
        );
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: shimmerText 4s linear infinite;
      }
      @keyframes shimmerText {
        from { background-position: 200% center; }
        to   { background-position: -200% center; }
      }

      .text-grad-blue {
        background: linear-gradient(135deg, #93c5fd 0%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* ── Card ────────────────────────────────────── */
      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 1rem;
        transition:
          background  0.25s ease,
          border-color 0.25s ease,
          transform   0.3s cubic-bezier(0.16, 1, 0.3, 1),
          box-shadow  0.3s ease;
      }
      .card:hover {
        background: var(--card-h);
        border-color: var(--border-h);
        transform: translateY(-3px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
      }
      /* Glow card — versión con glow azul al hover */
      .card-glow:hover {
        border-color: rgba(59, 130, 246, 0.4);
        box-shadow:
          0 12px 40px rgba(0, 0, 0, 0.5),
          0 0 0 1px rgba(59, 130, 246, 0.15),
          0 0 30px rgba(59, 130, 246, 0.08);
      }

      /* ── Label monospace ─────────────────────────── */
      .label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6875rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--lo);
      }

      /* ── Tag pill ────────────────────────────────── */
      .tag {
        display: inline-flex;
        align-items: center;
        padding: 0.22rem 0.65rem;
        border-radius: 999px;
        font-size: 0.6875rem;
        font-family: 'JetBrains Mono', monospace;
        background: #1a1a22;
        border: 1px solid #2e2e3a;
        color: var(--mid);
        transition: color 0.2s, background 0.2s, border-color 0.2s, transform 0.2s;
      }
      .tag:hover {
        background: rgba(59, 130, 246, 0.12);
        border-color: rgba(59, 130, 246, 0.35);
        color: var(--accent-l);
        transform: translateY(-1px);
      }

      /* ── Buttons ─────────────────────────────────── */
      .btn-primary {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-size: 0.875rem;
        font-weight: 600;
        background: var(--accent);
        color: #fff;
        border: 1px solid var(--accent);
        overflow: hidden;
        transition:
          background 0.2s,
          transform  0.25s cubic-bezier(0.16, 1, 0.3, 1),
          box-shadow 0.25s;
      }
      /* Shine sweep on hover */
      .btn-primary::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.2) 50%, transparent 60%);
        transform: translateX(-100%);
        transition: transform 0.45s ease;
      }
      .btn-primary:hover::before { transform: translateX(100%); }
      .btn-primary:hover {
        background: var(--accent-h);
        border-color: var(--accent-h);
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(59, 130, 246, 0.4);
      }
      .btn-primary:active { transform: translateY(0); }

      .btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-size: 0.875rem;
        font-weight: 500;
        background: transparent;
        border: 1px solid var(--border-h);
        color: var(--mid);
        transition:
          background  0.2s,
          border-color 0.2s,
          color       0.2s,
          transform   0.25s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .btn-ghost:hover {
        background: #1a1a22;
        border-color: var(--accent);
        color: var(--hi);
        transform: translateY(-2px);
      }
      .btn-ghost:active { transform: translateY(0); }

      /* ── Divider ─────────────────────────────────── */
      .divider { border-color: var(--border); }

      /* ── Input ───────────────────────────────────── */
      .input {
        width: 100%;
        padding: 0.75rem 1rem;
        border-radius: 0.75rem;
        background: #0f0f14;
        border: 1px solid var(--border);
        color: var(--hi);
        font-size: 0.875rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
      }
      .input::placeholder { color: var(--lo); }
      .input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
      }

      /* ── Fade-up keyframe (usado inline en Hero) ── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      /* ── Cursor blink ────────────────────────────── */
      @keyframes cursorBlink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0; }
      }
      .cursor-blink { animation: cursorBlink 1s step-start infinite; }

      /* ── Float ───────────────────────────────────── */
      @keyframes floatY {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-8px); }
      }
      .float { animation: floatY 3.5s ease-in-out infinite; }

      /* ── Glow pulse (dots en timeline) ───────────── */
      @keyframes glowPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(59,130,246,0.4); }
        50%       { box-shadow: 0 0 0 6px rgba(59,130,246,0); }
      }
      .dot-pulse { animation: glowPulse 2s ease-in-out infinite; }

      /* ── Background aurora ───────────────────────── */
      @keyframes auroraMove {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33%       { transform: translate(30px, -20px) scale(1.05); }
        66%       { transform: translate(-20px, 15px) scale(0.97); }
      }
      .aurora { animation: auroraMove 12s ease-in-out infinite; }
    </style>
  </body>
</html>
